{
  "name": "shuck-action",
  "version": "1.0.0",
  "private": true,
  "description": "Install and run Shuck in GitHub Actions",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --minify --source-map",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "package:check": "pnpm build && git diff --exit-code -- dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm package:check"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/tool-cache": "4.0.0",
    "detect-libc": "2.1.2",
    "semver": "7.8.5",
    "string-argv": "0.3.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^26.1.1",
    "@types/semver": "7.7.1",
    "@vercel/ncc": "0.44.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
